{
  "name": "homefolio",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vp dev --port 3000",
    "build": "vp build",
    "build:cf": "NITRO_PRESET=cloudflare-module vp build",
    "preview": "vp preview",
    "cf:preview": "pnpm build:cf && wrangler dev",
    "cf:deploy": "pnpm build:cf && wrangler deploy",
    "cf:tail": "wrangler tail homefolio",
    "cf:secret": "wrangler secret put --name homefolio",
    "test": "vp test run",
    "check": "vp fmt . --check && vp exec oxlint src",
    "check:fix": "vp fmt . --write && vp exec oxlint src --fix",
    "typecheck": "vp exec tsc --noEmit",
    "check:full": "vp run check && vp run typecheck",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "konva": "^10.3.0",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-konva": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260602.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "msw": "^2.14.6",
    "oxlint": "^1.68.0",
    "postgres": "^3.4.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.96.0"
  },
  "packageManager": "pnpm@11.5.1"
}
